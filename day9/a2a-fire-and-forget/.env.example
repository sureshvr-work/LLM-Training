# Copy to `.env` (next to docker-compose.yml) and fill in. Never commit real keys.

# ─── LLM: the brain for the Research Agent ──────────────────────────────────
# Which provider runs the loop. One of: openai | anthropic   (no mock)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ─── Demo pacing ─────────────────────────────────────────────────────────────
# How many seconds the Research Agent spends "working" before it POSTs the
# result to the orchestrator's webhook. Turn this up in class to make the
# fire-and-forget gap unmistakable; turn it down for a quick sanity check.
RESEARCH_SECONDS=12
