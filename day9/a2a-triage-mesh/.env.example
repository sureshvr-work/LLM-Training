# Everything here is OPTIONAL. The mesh runs end to end on the default `mock`
# engine with NO keys — `docker compose up --build` is all you need.
#
# Add a key only if you want a real model to do the router's extraction and each
# specialist's reasoning. The A2A wire — cards, discovery, tasks, artifacts — is
# identical either way; only the thinking behind each card changes.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# demo pacing — seconds between streamed steps (router sets this for itself)
# STEP_DELAY=0.45

# SPECIALIST capability: advertise streaming in this agent's card. Set false on a
# container to prove the router auto-falls back to message/send for it. (The
# compose file already sets this on dermatology.)
# STREAMING=false

# advanced: override the router's peer list (defaults to the compose service names)
# PEERS=http://cardiology:8000,http://pulmonology:8000,http://dermatology:8000,http://neurology:8000

# ROUTER real kill-switch (compose sets these + mounts the docker socket). Grants
# host-level Docker control — keep off outside a trusted local demo.
# DOCKER_CONTROL=true
# CONTAINER_PREFIX=mesh-
# DOCKER_SOCK=/var/run/docker.sock
