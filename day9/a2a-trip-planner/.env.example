# Copy to `.env` (next to docker-compose.yml) and fill in. Never commit real keys.

# ─── LLM: the brain for BOTH specialist agents ──────────────────────────────
# Which provider runs the loops. One of: openai | anthropic   (no mock)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ─── Flights: real data ─────────────────────────────────────────────────────
# Your AviationStack access key (aviationstack.com).
AVIATIONSTACK_KEY=

# ─── Offline / CI toggles (leave empty for live APIs) ───────────────────────
# These stub only the external DATA APIs, not the LLM. Handy if venue wifi
# blocks Open-Meteo / AviationStack. Set to 1 to enable.
WEATHER_STUB=
FLIGHTS_STUB=
