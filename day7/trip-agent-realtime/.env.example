# ── LLM engines (need at least one) ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# optional model overrides
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── live tools ──
GEOAPIFY_KEY=your-geoapify-key        # geocode + places
TAVILY_API_KEY=tvly-...               # web search
AVIATIONSTACK_KEY=your-aviationstack-key   # flights
# Open-Meteo (weather) needs NO key.

# ── plan-ready notifications (optional) ──
RESEND_API_KEY=re_...                 # email sending
# NOTIFY_FROM=onboarding@resend.dev   # default works without a verified domain
NOTIFY_EMAIL_TO=                      # where to email the finished plan

# ── tunables (optional) ──
# HTTP_TIMEOUT=12
# HTTP_RETRIES=2
# MAX_TURNS=10
