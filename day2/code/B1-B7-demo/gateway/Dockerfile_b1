# The guardrail gateway image - small and simple.
FROM python:3.12-slim

WORKDIR /app

# Install just what the gateway needs.
RUN pip install --no-cache-dir fastapi uvicorn httpx

# Copy the gateway code in.
COPY gateway.py .


# The gateway listens on port 8000 inside the container.
# (docker-compose maps host:8001 → container:8000)
EXPOSE 8000

# Start it.
CMD ["uvicorn", "gateway:app", "--host", "0.0.0.0", "--port", "8000"]

